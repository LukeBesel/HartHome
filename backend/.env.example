# ─── HartHome backend environment ──────────────────────────────────────────
# Copy to ".env" for local development. In production (Railway, Render, Fly,
# Docker, etc.) set these as environment variables in the platform dashboard.
#
# Everything is optional. With nothing set, the app runs fully — the first
# real signup becomes the household owner and the database starts empty.

# ─── Core ──────────────────────────────────────────────────────────────────
# NODE_ENV=production          # set to "production" on your host
# PORT=3001                    # the platform usually sets this for you

# Public base URL of the deployed app (used to lock down CORS in production).
# APP_URL=https://yourhome.up.railway.app

# Comma-separated extra browser origins allowed to call the API.
# ALLOWED_ORIGINS=https://home.yourdomain.com

# ─── Database (IMPORTANT in production) ─────────────────────────────────────
# Point the SQLite database at a PERSISTENT volume so data survives redeploys.
# On Railway/Render, mount a volume (e.g. at /data) and set:
# DATABASE_PATH=/data/harthome.db

# ─── Development convenience ────────────────────────────────────────────────
# Seeds a demo household ("The Hart Family") with sample members and data
# (owner@harthome.demo / Demo123!). NEVER enable in production — it ships known
# credentials. Set to "true" only for local development.
SEED_DEMO_DATA=true
